{
    "name": "letsinnovate-io/wordpress-starter",
    "description": "Starter project for building WordPress sites with the WordPress Blocks plugin",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Nathan Bate",
            "homepage": "https://nathanbate.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "github",
            "url": "https://github.com/letsinnovate-io/wordpress-blocks"
        },
        {
            "type": "github",
            "url": "https://github.com/letsinnovate-io/block-templates"
        }
    ],
    "require": {
        "php": "^8.2",
        "composer/installers": "^2.0",
        "vlucas/phpdotenv": "^5.6",
        "letsinnovate-io/wordpress-blocks": "dev-main"
    },
    "extra": {
        "installer-paths": {
            "web/wp-content/plugins/{$name}/": ["type:wordpress-plugin"],
            "web/wp-content/themes/{$name}/": ["type:wordpress-theme"]
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        },
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    }
}
