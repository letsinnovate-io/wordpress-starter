# WordPress Blocks — Environment Configuration
# Copy to .env and fill in your values.
# In DDEV, database settings are provided automatically.

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=wordpress
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_CHARSET=utf8
DB_COLLATE=
DB_PREFIX=wp_

# ── URLs ──────────────────────────────────────────────────────────────────────
WP_HOME=https://example.com
WP_SITEURL=${WP_HOME}

# ── Environment ───────────────────────────────────────────────────────────────
WP_ENV=production
WP_DEBUG=false
WP_DEBUG_LOG=false
WP_DEBUG_DISPLAY=false

# ── Authentication Keys and Salts ─────────────────────────────────────────────
# Generate fresh values at: https://roots.io/salts.html
AUTH_KEY=generate-me
SECURE_AUTH_KEY=generate-me
LOGGED_IN_KEY=generate-me
NONCE_KEY=generate-me
AUTH_SALT=generate-me
SECURE_AUTH_SALT=generate-me
LOGGED_IN_SALT=generate-me
NONCE_SALT=generate-me
