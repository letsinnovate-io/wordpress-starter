# WordPress Blocks — Environment Configuration
# Copy to .env and fill in your values.
# In DDEV, database settings are provided automatically.

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=wordpress
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_CHARSET=utf8
DB_COLLATE=
DB_PREFIX=wp_

# ── URLs ──────────────────────────────────────────────────────────────────────
WP_HOME=https://example.com
WP_SITEURL=${WP_HOME}

# ── Environment ───────────────────────────────────────────────────────────────
WP_ENV=production
WP_DEBUG=false
WP_DEBUG_LOG=false
WP_DEBUG_DISPLAY=false

# ── Authentication Keys and Salts ─────────────────────────────────────────────
# Generate fresh values at: https://roots.io/salts.html
AUTH_KEY=generate-me
SECURE_AUTH_KEY=generate-me
LOGGED_IN_KEY=generate-me
NONCE_KEY=generate-me
AUTH_SALT=generate-me
SECURE_AUTH_SALT=generate-me
LOGGED_IN_SALT=generate-me
NONCE_SALT=generate-me

# ── Object Storage (optional) ────────────────────────────────────────────────
# Configure these to enable the object storage media library.
# All settings can also be configured in WP Blocks > Settings in the admin.
# Values here are used as defaults; admin settings override them.
#
# Provider: s3, do-spaces, r2, or custom-s3
#WPB_STORAGE_PROVIDER=do-spaces
#WPB_STORAGE_BUCKET=my-bucket
#WPB_STORAGE_REGION=nyc3
#WPB_STORAGE_ENDPOINT=https://nyc3.digitaloceanspaces.com
#WPB_STORAGE_KEY=your-access-key
#WPB_STORAGE_SECRET=your-secret-key
#WPB_STORAGE_CDN_URL=https://my-bucket.nyc3.cdn.digitaloceanspaces.com
#WPB_STORAGE_PATH_PREFIX=wp-blocks
#WPB_STORAGE_R2_ACCOUNT_ID=
